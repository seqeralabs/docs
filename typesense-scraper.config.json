    {
      "url": "https://docs.seqera.io/platform-enterprise/",
      "selectors_key": "platform-enterprise"
    },
    {
      "url": "https://docs.seqera.io/platform-cloud/",
      "selectors_key": "platform-cloud"
    },
    {
      "url": "https://docs.seqera.io/platform-cli/",
