# Platform Enterprise
# ════════════════════════════════════════════════════════════════

# Versioned URLs for renamed pages (PostHog 404 data, 90d to 2026-06-11).
# These explicit :version rules must come BEFORE the version strips below,
# otherwise the strip fires first and lands on the pre-rename 404.
/platform-enterprise/:version/enterprise/configuration/authentication  /platform-enterprise/enterprise/configuration/authentication/overview  301
/platform-enterprise/:version/enterprise/kubernetes       /platform-enterprise/enterprise/platform-kubernetes      301
/platform-enterprise/:version/enterprise/docker-compose   /platform-enterprise/enterprise/platform-docker-compose  301

# Retired version strips (~120 hits/90d from bookmarks and Google's index).
# 24.1/24.2 are still live versions, so for those these rules only catch 404s
# within the version (Netlify redirects don't shadow existing pages).
/platform-enterprise/22.4/*    /platform-enterprise/:splat    301
/platform-enterprise/23.1/*    /platform-enterprise/:splat    301
/platform-enterprise/23.2/*    /platform-enterprise/:splat    301
/platform-enterprise/23.3/*    /platform-enterprise/:splat    301
/platform-enterprise/23.4/*    /platform-enterprise/:splat    301
/platform-enterprise/24.1/*    /platform-enterprise/:splat    301
/platform-enterprise/24.2/*    /platform-enterprise/:splat    301
/platform-enterprise/24.3/*    /platform-enterprise/:splat    301

# Two URLs concatenated in the email HTML
/platform-enterprise/data/data-lineageplatform-enterprise/launch/advanced   /platform-enterprise/data/data-lineage   301

# Renamed and moved pages
/platform-enterprise/enterprise/configuration/authentication   /platform-enterprise/enterprise/configuration/authentication/overview   301
/platform-enterprise/enterprise/install-co-scientist   /platform-enterprise/co-scientist/installation   301
/platform-enterprise/enterprise/install-seqera-ai      /platform-enterprise/enterprise/install-seqera-coscientist   301

# These redirects reverse the existing 301's
# See https://moz.com/blog/can-you-reverse-a-301-redirect
/platform-enterprise/:version/platform-enterprise /platform-enterprise/:version 301
/platform-enterprise/platform-enterprise /platform-enterprise 301

# Drop the latest functionality: redirect users to the "current version",
# which is the base URL
/platform-enterprise/latest/platform-enterprise /platform-enterprise 301
/platform-enterprise/latest/* /platform-enterprise/:splat 301
/platform-enterprise/latest /platform-enterprise 301

# Co-Scientist docs: seqera-ai path renamed to co-scientist
/platform-enterprise/seqera-ai/get-started       /platform-enterprise/co-scientist/quickstart        301
/platform-enterprise/26.1/seqera-ai/get-started  /platform-enterprise/26.1/co-scientist/quickstart   301

# Catch-all: rename seqera-ai path to co-scientist (Enterprise, all versions)
/platform-enterprise/seqera-ai/*                /platform-enterprise/co-scientist/:splat            301
/platform-enterprise/:version/seqera-ai/*       /platform-enterprise/:version/co-scientist/:splat   301

